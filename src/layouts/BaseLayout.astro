---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Giordon Stark, PhD",
  description = "Giordon Stark's online webpage.",
} = Astro.props;

const siteUrl = "https://giordonstark.com";
const ogImage = `${siteUrl}/img/profile.jpg`;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-V386D3ZRE5"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-V386D3ZRE5");
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts: Satoshi (display) + Geist (body) via Fontshare / CDN -->
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@700,500,400&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="d9a292bc-59fa-4212-9fca-30a34ff05a16"></script>
  </head>
  <body class="bg-brand-bg font-body text-brand-text antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-M79B5V7"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- Section fade-in via IntersectionObserver -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        const observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px 200px 0px" },
        );
        document.querySelectorAll(".section-fade").forEach(function (el) {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>

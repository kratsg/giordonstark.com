---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import CollisionHero from '../components/CollisionHero.astro';
import About from '../components/About.astro';
import Education from '../components/Education.astro';
import Research from '../components/Research.astro';
import Software from '../components/Software.astro';
import Awards from '../components/Awards.astro';
import Teaching from '../components/Teaching.astro';
import Media from '../components/Media.astro';
import Service from '../components/Service.astro';
import Talks from '../components/Talks.astro';
import Interpreting from '../components/Interpreting.astro';
---

<BaseLayout
  title="Giordon Stark, PhD"
  description="Giordon Stark's online webpage — Deaf project scientist and experimental particle physicist, ATLAS/CERN, UC Santa Cruz."
>
  <!-- Fixed particle collision canvas (decorative, behind content) -->
  <CollisionHero />

  <!-- Sidebar navigation -->
  <Nav />

  <!-- Main content, offset right on desktop for sidebar -->
  <main class="lg:pl-64 relative" style="z-index: 1;">
    <About />
    <Education />
    <Research />
    <Software />
    <Awards />
    <Teaching />
    <Media />
    <Service />
    <Talks />
    <Interpreting />
  </main>
</BaseLayout>

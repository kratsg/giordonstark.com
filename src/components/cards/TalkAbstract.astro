---
export interface TalkAbstractEntry {
  title: string;
  abstract: string;
  footer?: string;
}

interface Props {
  entry: TalkAbstractEntry;
  index: number;
}

const { entry, index } = Astro.props;
const id = `abstract-${index}`;
---

<!-- Expandable abstract card -->
<div class="rounded-2xl bg-white ring-1 ring-black/5 overflow-hidden">
  <button
    class="w-full text-left px-6 py-5 flex items-start justify-between gap-4 hover:bg-gray-50/60 transition-colors duration-200"
    aria-expanded="false"
    aria-controls={id}
    data-abstract-toggle
  >
    <h3 class="font-display font-semibold text-base text-brand-text leading-snug">
      {entry.title}
    </h3>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="w-5 h-5 text-brand-muted shrink-0 transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]"
      data-chevron
    >
      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
    </svg>
  </button>

  <div id={id} class="hidden px-6 pb-6" data-abstract-body>
    <p class="text-sm text-brand-muted leading-relaxed mb-4 whitespace-pre-wrap">
      {entry.abstract}
    </p>
    {entry.footer && (
      <p class="text-xs text-brand-muted italic border-t border-gray-100 pt-3 mt-3">
        {entry.footer}
      </p>
    )}
  </div>
</div>

<script>
  // Accordion toggle for each abstract card
  document.querySelectorAll('[data-abstract-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const body = btn.nextElementSibling as HTMLElement | null;
      const chevron = btn.querySelector('[data-chevron]') as SVGElement | null;

      btn.setAttribute('aria-expanded', String(!expanded));
      body?.classList.toggle('hidden', expanded);
      if (chevron) {
        chevron.style.transform = expanded ? '' : 'rotate(180deg)';
      }
    });
  });
</script>

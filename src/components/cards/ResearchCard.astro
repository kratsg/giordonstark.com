---
export interface TimelineEntry {
  year: number | string;
  label: string;
  url?: string;
}

export interface ResearchLink {
  label: string;
  url: string;
  icon?: string;
}

export interface ResearchProject {
  title: string;
  role: string;
  subtitle?: string;
  images?: string[];
  description?: string;
  details?: string[];
  timeline?: TimelineEntry[];
  links?: ResearchLink[];
}

interface Props {
  project: ResearchProject;
}

const { project } = Astro.props;
---

<!-- Double-bezel card architecture -->
<div class="rounded-[1.75rem] bg-white/60 ring-1 ring-black/5 p-1.5 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-1 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.08)]">
  <div class="rounded-[calc(1.75rem-6px)] bg-white shadow-[inset_0_1px_1px_rgba(255,255,255,0.8)] p-6 h-full flex flex-col">

    <!-- Header -->
    <div class="mb-4">
      <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
        <h3 class="font-display font-bold text-lg text-brand-text leading-tight">
          {project.title}
        </h3>
        {project.subtitle && (
          <span class="shrink-0 text-[11px] text-brand-muted bg-gray-50 border border-gray-100 px-2.5 py-1 rounded-full font-medium">
            {project.subtitle}
          </span>
        )}
      </div>
      <p class="text-sm font-medium text-brand-accent">{project.role}</p>
    </div>

    <!-- Description -->
    {project.description && (
      <p class="text-sm text-brand-muted leading-relaxed mb-4 flex-1">
        {project.description}
      </p>
    )}

    <!-- Details list -->
    {project.details && project.details.length > 0 && (
      <ul class="space-y-1.5 mb-4">
        {project.details.map((detail) => (
          <li class="flex gap-2 text-sm text-brand-muted">
            <span class="mt-1.5 shrink-0 w-1 h-1 rounded-full bg-brand-accent/60"></span>
            <span>{detail}</span>
          </li>
        ))}
      </ul>
    )}

    <!-- Timeline strip -->
    {project.timeline && project.timeline.length > 0 && (
      <div class="mt-auto mb-4 pt-4 border-t border-gray-100">
        <p class="text-[10px] uppercase tracking-[0.15em] text-brand-muted font-medium mb-3">Timeline</p>
        <div class="space-y-2">
          {project.timeline.map((entry) => (
            <div class="flex items-baseline gap-3">
              <span class="shrink-0 text-[11px] font-mono font-semibold text-brand-accent w-10">
                {entry.year}
              </span>
              <span class="w-1.5 h-1.5 shrink-0 rounded-full bg-gray-300 mt-[3px]"></span>
              {entry.url ? (
                <a
                  href={entry.url}
                  target="_blank"
                  rel="noopener"
                  class="text-xs text-brand-muted hover:text-brand-accent transition-colors duration-200 underline underline-offset-2 decoration-gray-300 hover:decoration-brand-accent"
                >
                  {entry.label}
                </a>
              ) : (
                <span class="text-xs text-brand-muted">{entry.label}</span>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Links -->
    {project.links && project.links.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-gray-100">
        {project.links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 text-xs font-medium text-brand-muted hover:text-brand-accent bg-gray-50 hover:bg-gray-100 border border-gray-100 px-3 py-1.5 rounded-full transition-all duration-200 active:scale-[0.98]"
          >
            {link.icon === 'book' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
                <path d="M7.5 1.5A1.5 1.5 0 006 3v10a.5.5 0 00.5.5h7a.5.5 0 00.5-.5V3a1.5 1.5 0 00-1.5-1.5h-5zm.5 1h4a.5.5 0 01.5.5v8H7V3a.5.5 0 01.5-.5zM2.5 3A.5.5 0 002 3.5v9a1 1 0 001 1h4V4H3a.5.5 0 01-.5-.5z"/>
              </svg>
            )}
            {link.icon === 'code' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
                <path fill-rule="evenodd" d="M10.28 1.22a.75.75 0 010 1.06L6.56 6l3.72 3.72a.75.75 0 11-1.06 1.06L4.94 6.53a.75.75 0 010-1.06l4.28-4.25a.75.75 0 011.06 0z" clip-rule="evenodd"/>
              </svg>
            )}
            {link.label}
          </a>
        ))}
      </div>
    )}

  </div>
</div>

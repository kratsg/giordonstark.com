---
export interface TimelineEntry {
  year: number | string;
  label: string;
  url?: string;
}

export interface ResearchLink {
  label: string;
  url: string;
  icon?: string;
}

export interface ResearchProject {
  title: string;
  role: string;
  subtitle?: string;
  images?: string[];
  description?: string;
  details?: string[];
  timeline?: TimelineEntry[];
  links?: ResearchLink[];
}

interface Props {
  project: ResearchProject;
}

const { project } = Astro.props;
---

<!-- Double-bezel card architecture -->
<div
  class="rounded-[1.75rem] bg-white/60 p-1.5 ring-1 ring-black/5 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-1 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.08)]"
>
  <div
    class="flex h-full flex-col rounded-[calc(1.75rem-6px)] bg-white p-6 shadow-[inset_0_1px_1px_rgba(255,255,255,0.8)]"
  >
    <!-- Header -->
    <div class="mb-4">
      <div class="mb-1 flex flex-wrap items-start justify-between gap-2">
        <h3
          class="font-display text-brand-text text-lg leading-tight font-bold"
        >
          {project.title}
        </h3>
        {
          project.subtitle && (
            <span class="text-brand-muted shrink-0 rounded-full border border-gray-100 bg-gray-50 px-2.5 py-1 text-[11px] font-medium">
              {project.subtitle}
            </span>
          )
        }
      </div>
      <p class="text-brand-accent text-sm font-medium">{project.role}</p>
    </div>

    <!-- Description -->
    {
      project.description && (
        <p class="text-brand-muted mb-4 flex-1 text-sm leading-relaxed">
          {project.description}
        </p>
      )
    }

    <!-- Details list -->
    {
      project.details && project.details.length > 0 && (
        <ul class="mb-4 space-y-1.5">
          {project.details.map((detail) => (
            <li class="text-brand-muted flex gap-2 text-sm">
              <span class="bg-brand-accent/60 mt-1.5 h-1 w-1 shrink-0 rounded-full" />
              <span>{detail}</span>
            </li>
          ))}
        </ul>
      )
    }

    <!-- Timeline strip -->
    {
      project.timeline && project.timeline.length > 0 && (
        <div class="mt-auto mb-4 border-t border-gray-100 pt-4">
          <p class="text-brand-muted mb-3 text-[10px] font-medium tracking-[0.15em] uppercase">
            Timeline
          </p>
          <div class="space-y-2">
            {project.timeline.map((entry) => (
              <div class="flex items-baseline gap-3">
                <span class="text-brand-accent w-10 shrink-0 font-mono text-[11px] font-semibold">
                  {entry.year}
                </span>
                <span class="mt-[3px] h-1.5 w-1.5 shrink-0 rounded-full bg-gray-300" />
                {entry.url ? (
                  <a
                    href={entry.url}
                    target="_blank"
                    rel="noopener"
                    class="text-brand-muted hover:text-brand-accent hover:decoration-brand-accent text-xs underline decoration-gray-300 underline-offset-2 transition-colors duration-200"
                  >
                    {entry.label}
                  </a>
                ) : (
                  <span class="text-brand-muted text-xs">{entry.label}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Links -->
    {
      project.links && project.links.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-2 border-t border-gray-100 pt-4">
          {project.links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener"
              class="text-brand-muted hover:text-brand-accent inline-flex items-center gap-1.5 rounded-full border border-gray-100 bg-gray-50 px-3 py-1.5 text-xs font-medium transition-all duration-200 hover:bg-gray-100 active:scale-[0.98]"
            >
              {link.icon === "book" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="h-3 w-3"
                >
                  <path d="M7.5 1.5A1.5 1.5 0 006 3v10a.5.5 0 00.5.5h7a.5.5 0 00.5-.5V3a1.5 1.5 0 00-1.5-1.5h-5zm.5 1h4a.5.5 0 01.5.5v8H7V3a.5.5 0 01.5-.5zM2.5 3A.5.5 0 002 3.5v9a1 1 0 001 1h4V4H3a.5.5 0 01-.5-.5z" />
                </svg>
              )}
              {link.icon === "code" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="h-3 w-3"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10.28 1.22a.75.75 0 010 1.06L6.56 6l3.72 3.72a.75.75 0 11-1.06 1.06L4.94 6.53a.75.75 0 010-1.06l4.28-4.25a.75.75 0 011.06 0z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              {link.icon === "file-text" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="h-3 w-3"
                >
                  <path d="M5 4a.5.5 0 000 1h6a.5.5 0 000-1H5zm-.5 2.5A.5.5 0 015 6h6a.5.5 0 010 1H5a.5.5 0 01-.5-.5zM5 8a.5.5 0 000 1h6a.5.5 0 000-1H5zm0 2a.5.5 0 000 1h3a.5.5 0 000-1H5z" />
                  <path d="M9.5 0H4a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4.5L9.5 0zm0 1v2A1.5 1.5 0 0011 4.5h2V14a1 1 0 01-1 1H4a1 1 0 01-1-1V2a1 1 0 011-1h5.5z" />
                </svg>
              )}
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</div>

---
import yaml from "js-yaml";
import { readFileSync } from "node:fs";

interface Workshop {
  title: string;
  role: string;
  date: string;
  url?: string;
  description?: string;
}
interface CourseTaught {
  title: string;
  role: string;
  period: string;
  institution: string;
  description?: string;
}
interface CourseTA {
  course: string;
  institution: string;
  period: string;
}
interface OtherInstruction {
  role: string;
  organization: string;
  period?: string;
  description?: string;
}
interface TeachingData {
  workshops_and_tutorials: Workshop[];
  courses_taught: CourseTaught[];
  courses_ta: CourseTA[];
  other_instruction: OtherInstruction[];
}

interface Mentee {
  name: string;
  institution: string;
  project: string;
  period: string;
  url?: string;
}
interface MenteesData {
  undergraduate: Mentee[];
  graduate: Mentee[];
}

const teachingData = yaml.load(
  readFileSync("src/data/teaching.yaml", "utf8"),
) as TeachingData;

const menteesData = yaml.load(
  readFileSync("src/data/mentees.yaml", "utf8"),
) as MenteesData;

// Separate workshops that have descriptions (standalone materials) from regular workshops
const standaloneItems = teachingData.workshops_and_tutorials.filter(
  (w) => w.description,
);
const regularWorkshops = teachingData.workshops_and_tutorials.filter(
  (w) => !w.description,
);
---

<section
  id="teaching"
  class="section-fade relative bg-gray-50/60"
  style="z-index: 1;"
>
  <div class="mx-auto max-w-5xl px-6 py-20">
    <!-- Section header -->
    <div class="mb-12 flex items-center gap-4">
      <span class="bg-brand-accent h-px max-w-12 flex-1"></span>
      <h2
        class="font-display text-brand-text text-2xl font-bold tracking-tight"
      >
        Teaching &amp; Mentoring
      </h2>
    </div>

    <!-- Stats row -->
    <div class="mb-14 grid grid-cols-2 gap-4 sm:grid-cols-4">
      {
        [
          { num: "40+", label: "Workshops & Tutorials" },
          {
            num:
              String(
                teachingData.courses_taught.length +
                  teachingData.courses_ta.length,
              ) + "+",
            label: "Courses",
          },
          { num: "20+", label: "Undergrad Mentees" },
          { num: "10+", label: "Graduate Mentees" },
        ].map(({ num, label }) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-4 text-center">
            <p class="font-display text-brand-accent text-3xl font-bold tabular-nums">
              {num}
            </p>
            <p class="text-brand-muted mt-1 text-xs leading-snug">{label}</p>
          </div>
        ))
      }
    </div>

    <!-- Standalone educational materials -->
    {
      standaloneItems.length > 0 && (
        <div class="mb-14">
          <h3 class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase">
            <span>Curriculum Developed</span>
            <span class="h-px flex-1 bg-gray-200" />
          </h3>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
            {standaloneItems.map((item) => (
              <a
                href={item.url ?? "#"}
                target={item.url ? "_blank" : undefined}
                rel={item.url ? "noopener" : undefined}
                class="group hover:border-brand-accent/30 block rounded-2xl border border-gray-100 bg-white p-5 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-0.5"
              >
                <p class="text-brand-text group-hover:text-brand-accent mb-1 text-sm leading-snug font-semibold transition-colors duration-200">
                  {item.title}
                </p>
                <p class="text-brand-muted text-xs">
                  {item.role} · {item.date}
                </p>
                {item.description && (
                  <p class="text-brand-muted mt-2 line-clamp-2 text-xs leading-relaxed">
                    {item.description}
                  </p>
                )}
              </a>
            ))}
          </div>
        </div>
      )
    }

    <!-- Courses taught (student instructor / TA) -->
    <div class="mb-14">
      <h3
        class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase"
      >
        <span>Courses</span>
        <span class="h-px flex-1 bg-gray-200"></span>
      </h3>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Student-taught / lead TA courses -->
        <div>
          <p
            class="text-brand-muted mb-3 text-xs font-semibold tracking-wider uppercase"
          >
            Instructor / Lead TA
          </p>
          <div class="space-y-4">
            {
              teachingData.courses_taught.map((course) => (
                <div class="border-l-2 border-gray-100 pl-4">
                  <p class="text-brand-text text-sm font-medium">
                    {course.title}
                  </p>
                  <p class="text-brand-muted mt-0.5 text-xs">
                    {course.role} · {course.institution} · {course.period}
                  </p>
                  {course.description && (
                    <p class="text-brand-muted mt-1.5 text-xs leading-relaxed">
                      {course.description}
                    </p>
                  )}
                </div>
              ))
            }
          </div>
        </div>

        <!-- TA courses -->
        <div>
          <p
            class="text-brand-muted mb-3 text-xs font-semibold tracking-wider uppercase"
          >
            Teaching Assistant
          </p>
          <div class="space-y-2">
            {
              teachingData.courses_ta.map((course) => (
                <div class="flex flex-col gap-1 border-b border-gray-50 py-1.5 last:border-0 sm:flex-row sm:items-baseline sm:justify-between">
                  <p class="text-brand-text text-sm">{course.course}</p>
                  <p class="text-brand-muted shrink-0 text-xs">
                    {course.period}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Workshops list (collapsible) -->
    <div class="mb-14">
      <h3
        class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase"
      >
        <span>Workshops &amp; Tutorials ({regularWorkshops.length})</span>
        <span class="h-px flex-1 bg-gray-200"></span>
      </h3>

      <!-- Show recent 10, rest toggled -->
      <div class="divide-y divide-gray-100" id="workshops-list">
        {
          regularWorkshops.slice(0, 10).map((workshop) => (
            <div class="flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:justify-between">
              <div class="flex-1">
                {workshop.url ? (
                  <a
                    href={workshop.url}
                    target="_blank"
                    rel="noopener"
                    class="text-brand-text hover:text-brand-accent text-sm font-medium transition-colors duration-200"
                  >
                    {workshop.title}
                  </a>
                ) : (
                  <span class="text-brand-text text-sm font-medium">
                    {workshop.title}
                  </span>
                )}
                <span class="text-brand-muted ml-2 text-xs">
                  ({workshop.role})
                </span>
              </div>
              <span class="text-brand-muted shrink-0 text-xs">
                {workshop.date}
              </span>
            </div>
          ))
        }
      </div>

      {
        regularWorkshops.length > 10 && (
          <>
            <div id="workshops-extra" class="hidden divide-y divide-gray-100">
              {regularWorkshops.slice(10).map((workshop) => (
                <div class="flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:justify-between">
                  <div class="flex-1">
                    {workshop.url ? (
                      <a
                        href={workshop.url}
                        target="_blank"
                        rel="noopener"
                        class="text-brand-text hover:text-brand-accent text-sm font-medium transition-colors duration-200"
                      >
                        {workshop.title}
                      </a>
                    ) : (
                      <span class="text-brand-text text-sm font-medium">
                        {workshop.title}
                      </span>
                    )}
                    <span class="text-brand-muted ml-2 text-xs">
                      ({workshop.role})
                    </span>
                  </div>
                  <span class="text-brand-muted shrink-0 text-xs">
                    {workshop.date}
                  </span>
                </div>
              ))}
            </div>

            <button
              id="workshops-toggle"
              class="text-brand-accent hover:text-brand-accent/80 mt-4 text-sm font-medium transition-colors duration-200"
            >
              Show {regularWorkshops.length - 10} more workshops ↓
            </button>
          </>
        )
      }
    </div>

    <!-- Mentees -->
    <div>
      <h3
        class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase"
      >
        <span>Mentees</span>
        <span class="h-px flex-1 bg-gray-200"></span>
      </h3>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Undergraduate mentees -->
        <div>
          <p
            class="text-brand-muted mb-4 text-xs font-semibold tracking-wider uppercase"
          >
            Undergraduate ({menteesData.undergraduate.length})
          </p>
          <div class="space-y-2">
            {
              menteesData.undergraduate.map((mentee) => (
                <div class="flex flex-col gap-0.5 border-b border-gray-50 py-2 last:border-0">
                  <div class="flex items-baseline justify-between gap-2">
                    {mentee.url ? (
                      <a
                        href={mentee.url}
                        target="_blank"
                        rel="noopener"
                        class="text-brand-text hover:text-brand-accent text-sm font-medium transition-colors duration-200"
                      >
                        {mentee.name}
                      </a>
                    ) : (
                      <span class="text-brand-text text-sm font-medium">
                        {mentee.name}
                      </span>
                    )}
                    <span class="text-brand-muted shrink-0 text-xs tabular-nums">
                      {mentee.period}
                    </span>
                  </div>
                  <p class="text-brand-muted text-xs leading-snug">
                    {mentee.project}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Graduate mentees -->
        <div>
          <p
            class="text-brand-muted mb-4 text-xs font-semibold tracking-wider uppercase"
          >
            Graduate ({menteesData.graduate.length})
          </p>
          <div class="space-y-2">
            {
              menteesData.graduate.map((mentee) => (
                <div class="flex flex-col gap-0.5 border-b border-gray-50 py-2 last:border-0">
                  <div class="flex items-baseline justify-between gap-2">
                    {mentee.url ? (
                      <a
                        href={mentee.url}
                        target="_blank"
                        rel="noopener"
                        class="text-brand-text hover:text-brand-accent text-sm font-medium transition-colors duration-200"
                      >
                        {mentee.name}
                      </a>
                    ) : (
                      <span class="text-brand-text text-sm font-medium">
                        {mentee.name}
                      </span>
                    )}
                    <span class="text-brand-muted shrink-0 text-xs tabular-nums">
                      {mentee.period}
                    </span>
                  </div>
                  <p class="text-brand-muted text-xs leading-snug">
                    {mentee.project}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Other instruction -->
    <div class="mt-14">
      <h3
        class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase"
      >
        <span>Other Instruction</span>
        <span class="h-px flex-1 bg-gray-200"></span>
      </h3>
      <div class="space-y-4">
        {
          teachingData.other_instruction.map((item) => (
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <span class="text-brand-text text-sm font-medium">
                  {item.role}
                </span>
                <span class="text-brand-muted text-sm">
                  {" "}
                  · {item.organization}
                </span>
                {item.description && (
                  <p class="text-brand-muted mt-1 max-w-[55ch] text-xs leading-relaxed">
                    {item.description}
                  </p>
                )}
              </div>
              {item.period && (
                <span class="text-brand-muted shrink-0 text-xs">
                  {item.period}
                </span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById("workshops-toggle");
  const extra = document.getElementById("workshops-extra");

  if (toggle && extra) {
    toggle.addEventListener("click", () => {
      const isHidden = extra.classList.contains("hidden");
      extra.classList.toggle("hidden", !isHidden);
      toggle.textContent = isHidden
        ? "Show fewer workshops ↑"
        : `Show ${extra.children.length} more workshops ↓`;
    });
  }
</script>

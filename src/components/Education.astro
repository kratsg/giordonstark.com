---
import yaml from "js-yaml";
import { readFileSync } from "node:fs";

interface Advisor {
  name: string;
  url?: string;
}
interface Publication {
  label: string;
  url: string;
  note?: string;
}
interface Thesis {
  title: string;
  url?: string;
}
interface Degree {
  degree: string;
  institution: string;
  start: string;
  end: string;
  thesis?: Thesis;
  advisors?: Advisor[];
  publications?: Publication[];
}
interface EducationData {
  degrees: Degree[];
}

const { degrees } = yaml.load(
  readFileSync("src/data/education.yaml", "utf8"),
) as EducationData;
---

<section
  id="education"
  class="section-fade relative"
  style="z-index: 1; background: rgba(250,250,248,0.25);"
>
  <div class="mx-auto max-w-5xl px-6 py-20">
    <!-- Section header -->
    <div class="mb-12 flex items-center gap-4">
      <span class="bg-brand-accent h-px max-w-12 flex-1"></span>
      <h2
        class="font-display text-brand-text text-2xl font-bold tracking-tight"
      >
        Education
      </h2>
    </div>

    <div class="space-y-10">
      {
        degrees.map((entry) => (
          <div class="group hover:border-brand-accent/40 relative border-l-2 border-gray-100 pl-6 transition-colors duration-300">
            <div class="group-hover:bg-brand-accent absolute top-1.5 -left-[5px] h-2 w-2 rounded-full bg-gray-300 transition-colors duration-300" />

            <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="font-display text-brand-text text-xl leading-tight font-bold">
                  {entry.degree}
                </h3>
                <p class="text-brand-muted mt-0.5 font-medium">
                  {entry.institution}
                </p>
              </div>
              <span class="text-brand-muted shrink-0 self-start rounded-full border border-gray-100 bg-gray-50 px-3 py-1 text-sm">
                {entry.start} – {entry.end}
              </span>
            </div>

            <div class="text-brand-muted space-y-2 text-sm">
              {entry.thesis && (
                <p>
                  {"Thesis: "}
                  {entry.thesis.url ? (
                    <a
                      href={entry.thesis.url}
                      target="_blank"
                      rel="noopener"
                      class="text-brand-text hover:text-brand-accent hover:decoration-brand-accent font-medium underline decoration-gray-300 underline-offset-2 transition-colors duration-200"
                    >
                      {entry.thesis.title}
                    </a>
                  ) : (
                    entry.thesis.title
                  )}
                </p>
              )}
              {entry.advisors && entry.advisors.length > 0 && (
                <p>
                  {entry.advisors.length === 1 ? "Advisor: " : "Advisors: "}
                  {entry.advisors.map((advisor, i) => (
                    <>
                      {i > 0 && " and "}
                      {advisor.url ? (
                        <a
                          href={advisor.url}
                          target="_blank"
                          rel="noopener"
                          class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200"
                        >
                          {advisor.name}
                        </a>
                      ) : (
                        advisor.name
                      )}
                    </>
                  ))}
                </p>
              )}
              {entry.publications &&
                entry.publications.map((pub) => (
                  <p>
                    {"Published: "}
                    <a
                      href={pub.url}
                      target="_blank"
                      rel="noopener"
                      class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200"
                    >
                      {pub.label}
                    </a>
                    {pub.note && ` — ${pub.note}`}
                  </p>
                ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

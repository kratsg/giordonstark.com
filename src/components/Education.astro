---
// Education section -- hardcoded (two degrees, static content)
---

<section
  id="education"
  class="section-fade relative bg-gray-50/60"
  style="z-index: 1;"
>
  <div class="mx-auto max-w-5xl px-6 py-20">
    <!-- Section header -->
    <div class="mb-12 flex items-center gap-4">
      <span class="bg-brand-accent h-px max-w-12 flex-1"></span>
      <h2
        class="font-display text-brand-text text-2xl font-bold tracking-tight"
      >
        Education
      </h2>
    </div>

    <div class="space-y-10">
      <!-- PhD -->
      <div
        class="group hover:border-brand-accent/40 relative border-l-2 border-gray-100 pl-6 transition-colors duration-300"
      >
        <div
          class="group-hover:bg-brand-accent absolute top-1.5 -left-[5px] h-2 w-2 rounded-full bg-gray-300 transition-colors duration-300"
        >
        </div>

        <div
          class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between"
        >
          <div>
            <h3
              class="font-display text-brand-text text-xl leading-tight font-bold"
            >
              Doctor of Philosophy in Physics
            </h3>
            <p class="text-brand-muted mt-0.5 font-medium">
              University of Chicago
            </p>
          </div>
          <span
            class="text-brand-muted shrink-0 self-start rounded-full border border-gray-100 bg-gray-50 px-3 py-1 text-sm"
          >
            Sep 2012 – Jun 2018
          </span>
        </div>

        <div class="text-brand-muted space-y-2 text-sm">
          <p>
            Thesis:
            <a
              href="https://kratsg.github.io/thesis/?utm_source=giordonstark.com"
              target="_blank"
              rel="noopener"
              class="text-brand-text hover:text-brand-accent hover:decoration-brand-accent font-medium underline decoration-gray-300 underline-offset-2 transition-colors duration-200"
            >
              The search for supersymmetry in hadronic final states using
              boosted object reconstruction
            </a>
          </p>
          <p>
            Advisor:
            <a
              href="https://hep.uchicago.edu/~DavidMiller/?utm_source=giordonstark.com"
              target="_blank"
              rel="noopener"
              class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200"
            >
              David W. Miller
            </a>
          </p>
          <p>
            Published:
            <a
              href="https://books.google.com/books?vid=ISBN978-3-030-34548-8"
              target="_blank"
              rel="noopener"
              class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200"
            >
              Springer Theses (ISBN 978-3-030-34548-8)
            </a>
            — Springer Thesis Award recipient
          </p>
        </div>
      </div>

      <!-- BS -->
      <div
        class="group hover:border-brand-accent/40 relative border-l-2 border-gray-100 pl-6 transition-colors duration-300"
      >
        <div
          class="group-hover:bg-brand-accent absolute top-1.5 -left-[5px] h-2 w-2 rounded-full bg-gray-300 transition-colors duration-300"
        >
        </div>

        <div
          class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between"
        >
          <div>
            <h3
              class="font-display text-brand-text text-xl leading-tight font-bold"
            >
              Bachelor of Science in Physics
            </h3>
            <p class="text-brand-muted mt-0.5 font-medium">
              California Institute of Technology
            </p>
          </div>
          <span
            class="text-brand-muted shrink-0 self-start rounded-full border border-gray-100 bg-gray-50 px-3 py-1 text-sm"
          >
            Sep 2008 – Jun 2012
          </span>
        </div>

        <div class="text-brand-muted space-y-2 text-sm">
          <p>
            Senior Thesis: Optical Coating Brownian Thermal Noise in
            Gravitational Wave Detectors
          </p>
          <p>Advisors: Kenneth Libbrecht and Harvey Newman</p>
          <p>
            Edward C. and Alice Stone Fellow (2010) — research at LIGO and
            Submillimeter Wave Observatory
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

---
// Education section -- hardcoded (two degrees, static content)
---

<section id="education" class="relative section-fade bg-brand-bg" style="z-index: 1;">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-12">
      <span class="h-px flex-1 max-w-[3rem] bg-brand-accent"></span>
      <h2 class="font-display font-bold text-2xl text-brand-text tracking-tight">
        Education
      </h2>
    </div>

    <div class="space-y-10">

      <!-- PhD -->
      <div class="group relative pl-6 border-l-2 border-gray-100 hover:border-brand-accent/40 transition-colors duration-300">
        <div class="absolute -left-[5px] top-1.5 w-2 h-2 rounded-full bg-gray-300 group-hover:bg-brand-accent transition-colors duration-300"></div>

        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
          <div>
            <h3 class="font-display font-bold text-xl text-brand-text leading-tight">
              Doctor of Philosophy in Physics
            </h3>
            <p class="text-brand-muted font-medium mt-0.5">University of Chicago</p>
          </div>
          <span class="shrink-0 text-sm text-brand-muted bg-gray-50 px-3 py-1 rounded-full border border-gray-100 self-start">
            Sep 2012 – Jun 2018
          </span>
        </div>

        <div class="space-y-2 text-sm text-brand-muted">
          <p>
            Thesis:
            <a
              href="https://kratsg.github.io/thesis/?utm_source=giordonstark.com"
              target="_blank"
              rel="noopener"
              class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200 underline underline-offset-2 decoration-gray-300 hover:decoration-brand-accent"
            >
              The search for supersymmetry in hadronic final states using boosted object reconstruction
            </a>
          </p>
          <p>
            Advisor:
            <a
              href="https://hep.uchicago.edu/~DavidMiller/?utm_source=giordonstark.com"
              target="_blank"
              rel="noopener"
              class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200"
            >
              David W. Miller
            </a>
          </p>
          <p>
            Published:
            <a
              href="https://books.google.com/books?vid=ISBN978-3-030-34548-8"
              target="_blank"
              rel="noopener"
              class="text-brand-text hover:text-brand-accent font-medium transition-colors duration-200"
            >
              Springer Theses (ISBN 978-3-030-34548-8)
            </a>
            — Springer Thesis Award recipient
          </p>
        </div>
      </div>

      <!-- BS -->
      <div class="group relative pl-6 border-l-2 border-gray-100 hover:border-brand-accent/40 transition-colors duration-300">
        <div class="absolute -left-[5px] top-1.5 w-2 h-2 rounded-full bg-gray-300 group-hover:bg-brand-accent transition-colors duration-300"></div>

        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
          <div>
            <h3 class="font-display font-bold text-xl text-brand-text leading-tight">
              Bachelor of Science in Physics
            </h3>
            <p class="text-brand-muted font-medium mt-0.5">California Institute of Technology</p>
          </div>
          <span class="shrink-0 text-sm text-brand-muted bg-gray-50 px-3 py-1 rounded-full border border-gray-100 self-start">
            Sep 2008 – Jun 2012
          </span>
        </div>

        <div class="space-y-2 text-sm text-brand-muted">
          <p>
            Senior Thesis: Optical Coating Brownian Thermal Noise in Gravitational Wave Detectors
          </p>
          <p>
            Advisors: Kenneth Libbrecht and Harvey Newman
          </p>
          <p>
            Edward C. and Alice Stone Fellow (2010) — research at LIGO and Submillimeter Wave Observatory
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

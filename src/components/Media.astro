---
import yaml from 'js-yaml';
import { readFileSync } from 'node:fs';
import MediaItem from './cards/MediaItem.astro';
import type { MediaEntry } from './cards/MediaItem.astro';

interface MediaData {
  items: MediaEntry[];
}

const { items } = yaml.load(
  readFileSync('src/data/media.yaml', 'utf8')
) as MediaData;
---

<section id="media" class="relative section-fade bg-brand-bg" style="z-index: 1;">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-12">
      <span class="h-px flex-1 max-w-[3rem] bg-brand-accent"></span>
      <h2 class="font-display font-bold text-2xl text-brand-text tracking-tight">
        Media &amp; Online Presence
      </h2>
    </div>

    <div>
      {items.map((item) => (
        <MediaItem item={item} />
      ))}
    </div>
  </div>
</section>

---
import yaml from "js-yaml";
import { readFileSync } from "node:fs";
import TalkAbstract from "./cards/TalkAbstract.astro";
import type { TalkAbstractEntry } from "./cards/TalkAbstract.astro";

interface TalkAbstractsData {
  speaker_bio: string;
  speaker_intro: string;
  abstracts: TalkAbstractEntry[];
}
interface Talk {
  type: string;
  venue: string;
  date: string;
  url?: string;
}
interface TalksData {
  talks: Talk[];
}

const abstractsData = yaml.load(
  readFileSync("src/data/talk_abstracts.yaml", "utf8"),
) as TalkAbstractsData;

const { talks } = yaml.load(
  readFileSync("src/data/talks.yaml", "utf8"),
) as TalksData;

const INVITED_TYPES = new Set(["Seminar", "Colloquium", "Plenary"]);
const invitedTalks = talks.filter((t) => INVITED_TYPES.has(t.type));
const contributedTalks = talks.filter((t) => !INVITED_TYPES.has(t.type));
---

<section
  id="talks"
  class="section-fade bg-brand-bg relative"
  style="z-index: 1;"
>
  <div class="mx-auto max-w-5xl px-6 py-20">
    <!-- Section header -->
    <div class="mb-12 flex items-center gap-4">
      <span class="bg-brand-accent h-px max-w-12 flex-1"></span>
      <h2
        class="font-display text-brand-text text-2xl font-bold tracking-tight"
      >
        Talk Invitations
      </h2>
    </div>

    <!-- Speaker intro (personal voice, verbatim) -->
    <div class="mb-12 rounded-2xl border border-gray-100 bg-gray-50 p-6">
      <p class="text-brand-muted text-sm leading-relaxed">
        {abstractsData.speaker_intro}
      </p>
    </div>

    <!-- Abstracts -->
    <div class="mb-14">
      <h3
        class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase"
      >
        <span>Talk Abstracts</span>
        <span class="h-px flex-1 bg-gray-100"></span>
      </h3>
      <div class="space-y-3">
        {
          abstractsData.abstracts.map((entry, i) => (
            <TalkAbstract entry={entry} index={i} />
          ))
        }
      </div>
    </div>

    <!-- Speaker bio -->
    <div class="mb-14 rounded-2xl border border-gray-100 bg-gray-50 p-6">
      <p
        class="text-brand-muted mb-3 text-[10px] font-medium tracking-[0.15em] uppercase"
      >
        Speaker Bio
      </p>
      <p class="text-brand-muted text-sm leading-relaxed">
        {abstractsData.speaker_bio}
      </p>
    </div>

    <!-- Prior talks: two-column split (invited vs contributed) -->
    <div>
      <h3
        class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase"
      >
        <span>Prior Talks ({talks.length})</span>
        <span class="h-px flex-1 bg-gray-100"></span>
      </h3>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Invited: Seminar / Colloquium / Plenary -->
        <div>
          <p
            class="text-brand-muted mb-3 text-xs font-semibold tracking-wider uppercase"
          >
            Invited ({invitedTalks.length})
          </p>
          <p class="text-brand-muted mb-4 text-[10px] tracking-wide">
            Seminar · Colloquium · Plenary
          </p>
          <div class="divide-y divide-gray-100">
            {
              invitedTalks.map((talk) => (
                <div class="flex flex-col gap-1 py-2.5 sm:flex-row sm:items-baseline sm:justify-between">
                  <div class="flex items-baseline gap-2">
                    <span class="bg-brand-accent/8 text-brand-accent shrink-0 rounded px-1.5 py-0.5 text-[9px] font-semibold tracking-wide uppercase">
                      {talk.type}
                    </span>
                    {talk.url ? (
                      <a
                        href={talk.url}
                        target="_blank"
                        rel="noopener"
                        class="text-brand-text hover:text-brand-accent text-sm transition-colors duration-200"
                      >
                        {talk.venue}
                      </a>
                    ) : (
                      <span class="text-brand-text text-sm">{talk.venue}</span>
                    )}
                  </div>
                  <span class="text-brand-muted shrink-0 text-xs tabular-nums">
                    {talk.date}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Contributed: Parallel / Poster -->
        <div>
          <p
            class="text-brand-muted mb-3 text-xs font-semibold tracking-wider uppercase"
          >
            Contributed ({contributedTalks.length})
          </p>
          <p class="text-brand-muted mb-4 text-[10px] tracking-wide">
            Parallel · Poster
          </p>
          <div class="divide-y divide-gray-100" id="contributed-list">
            {
              contributedTalks.slice(0, 10).map((talk) => (
                <div class="flex flex-col gap-1 py-2.5 sm:flex-row sm:items-baseline sm:justify-between">
                  <div class="flex items-baseline gap-2">
                    <span class="bg-brand-accent/8 text-brand-accent shrink-0 rounded px-1.5 py-0.5 text-[9px] font-semibold tracking-wide uppercase">
                      {talk.type}
                    </span>
                    {talk.url ? (
                      <a
                        href={talk.url}
                        target="_blank"
                        rel="noopener"
                        class="text-brand-text hover:text-brand-accent text-sm transition-colors duration-200"
                      >
                        {talk.venue}
                      </a>
                    ) : (
                      <span class="text-brand-text text-sm">{talk.venue}</span>
                    )}
                  </div>
                  <span class="text-brand-muted shrink-0 text-xs tabular-nums">
                    {talk.date}
                  </span>
                </div>
              ))
            }
          </div>
          {
            contributedTalks.length > 10 && (
              <>
                <div
                  id="contributed-extra"
                  class="hidden divide-y divide-gray-100"
                >
                  {contributedTalks.slice(10).map((talk) => (
                    <div class="flex flex-col gap-1 py-2.5 sm:flex-row sm:items-baseline sm:justify-between">
                      <div class="flex items-baseline gap-2">
                        <span class="bg-brand-accent/8 text-brand-accent shrink-0 rounded px-1.5 py-0.5 text-[9px] font-semibold tracking-wide uppercase">
                          {talk.type}
                        </span>
                        {talk.url ? (
                          <a
                            href={talk.url}
                            target="_blank"
                            rel="noopener"
                            class="text-brand-text hover:text-brand-accent text-sm transition-colors duration-200"
                          >
                            {talk.venue}
                          </a>
                        ) : (
                          <span class="text-brand-text text-sm">
                            {talk.venue}
                          </span>
                        )}
                      </div>
                      <span class="text-brand-muted shrink-0 text-xs tabular-nums">
                        {talk.date}
                      </span>
                    </div>
                  ))}
                </div>
                <button
                  id="contributed-toggle"
                  class="text-brand-accent hover:text-brand-accent/80 mt-4 text-sm font-medium transition-colors duration-200"
                >
                  Show {contributedTalks.length - 10} more ↓
                </button>
              </>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById("contributed-toggle");
  const extra = document.getElementById("contributed-extra");

  if (toggle && extra) {
    toggle.addEventListener("click", () => {
      const isHidden = extra.classList.contains("hidden");
      extra.classList.toggle("hidden", !isHidden);
      toggle.textContent = isHidden
        ? "Show fewer ↑"
        : `Show ${extra.children.length} more ↓`;
    });
  }
</script>

---
import yaml from "js-yaml";
import { readFileSync } from "node:fs";
import ResearchCard from "./cards/ResearchCard.astro";
import type { ResearchProject } from "./cards/ResearchCard.astro";

interface ResearchCategory {
  name: string;
  projects: ResearchProject[];
}
interface ResearchData {
  categories: ResearchCategory[];
}

const { categories } = yaml.load(
  readFileSync("src/data/research.yaml", "utf8"),
) as ResearchData;
---

<section
  id="research"
  class="section-fade bg-brand-bg relative"
  style="z-index: 1;"
>
  <div class="mx-auto max-w-5xl px-6 py-20">
    <!-- Section header -->
    <div class="mb-12 flex items-center gap-4">
      <span class="bg-brand-accent h-px max-w-12 flex-1"></span>
      <h2
        class="font-display text-brand-text text-2xl font-bold tracking-tight"
      >
        Analysis &amp; Instrumentation
      </h2>
    </div>

    {
      categories.map((category) => (
        <div class="mb-14 last:mb-0">
          {/* Category label */}
          <h3 class="text-brand-muted mb-6 flex items-center gap-3 text-[11px] font-medium tracking-[0.2em] uppercase">
            <span>{category.name}</span>
            <span class="h-px flex-1 bg-gray-100" />
          </h3>

          {/* Cards grid */}
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {category.projects.map((project) => (
              <ResearchCard project={project} />
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

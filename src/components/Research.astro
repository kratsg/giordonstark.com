---
import yaml from 'js-yaml';
import { readFileSync } from 'node:fs';
import ResearchCard from './cards/ResearchCard.astro';
import type { ResearchProject } from './cards/ResearchCard.astro';

interface ResearchCategory {
  name: string;
  projects: ResearchProject[];
}
interface ResearchData {
  categories: ResearchCategory[];
}

const { categories } = yaml.load(
  readFileSync('src/data/research.yaml', 'utf8')
) as ResearchData;
---

<section id="research" class="relative section-fade bg-brand-bg" style="z-index: 1;">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-12">
      <span class="h-px flex-1 max-w-[3rem] bg-brand-accent"></span>
      <h2 class="font-display font-bold text-2xl text-brand-text tracking-tight">
        Research &amp; Instrumentation
      </h2>
    </div>

    {categories.map((category) => (
      <div class="mb-14 last:mb-0">
        {/* Category label */}
        <h3 class="text-[11px] uppercase tracking-[0.2em] text-brand-muted font-medium mb-6 flex items-center gap-3">
          <span>{category.name}</span>
          <span class="h-px flex-1 bg-gray-100"></span>
        </h3>

        {/* Cards grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {category.projects.map((project) => (
            <ResearchCard project={project} />
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

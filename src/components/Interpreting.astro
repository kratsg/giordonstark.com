---
import yaml from "js-yaml";
import { readFileSync } from "node:fs";

interface InterpLink {
  label: string;
  url: string;
}
interface InterpItem {
  number: number;
  text: string;
  extra?: string;
  links?: InterpLink[];
}
interface InterpretingData {
  items: InterpItem[];
}

const { items } = yaml.load(
  readFileSync("src/data/interpreting.yaml", "utf8"),
) as InterpretingData;
---

<section
  id="interpreting"
  class="section-fade relative bg-gray-50/60"
  style="z-index: 1;"
>
  <div class="mx-auto max-w-5xl px-6 py-20">
    <!-- Section header -->
    <div class="mb-4 flex items-center gap-4">
      <span class="bg-brand-accent h-px max-w-12 flex-1"></span>
      <h2
        class="font-display text-brand-text text-2xl font-bold tracking-tight"
      >
        Interpreting
      </h2>
    </div>

    <!-- Brief intro -->
    <p class="text-brand-muted mb-12 max-w-[65ch] text-sm leading-relaxed">
      Information for ASL interpreters working with Giordon at conferences,
      seminars, and meetings.
    </p>

    <div class="space-y-6">
      {
        items.map((item) => (
          <div class="group flex gap-5">
            {/* Number */}
            <div class="bg-brand-accent/10 group-hover:bg-brand-accent/15 flex h-8 w-8 shrink-0 items-center justify-center rounded-full transition-colors duration-200">
              <span class="text-brand-accent text-xs font-bold tabular-nums">
                {item.number}
              </span>
            </div>

            {/* Content */}
            <div class="flex-1 pt-1">
              {/* Main text (verbatim) */}
              <p class="text-brand-text text-sm leading-relaxed">{item.text}</p>

              {/* Extra note (item 1 only) */}
              {item.extra && (
                <p class="text-brand-muted mt-2 text-sm leading-relaxed italic">
                  {item.extra}
                </p>
              )}

              {/* Inline links */}
              {item.links && item.links.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="text-brand-accent decoration-brand-accent/40 hover:text-brand-accent/80 hover:decoration-brand-accent text-xs font-medium underline underline-offset-2 transition-colors duration-200"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
